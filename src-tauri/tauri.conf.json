{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mnemo Med",
  "version": "1.0.0",
  "identifier": "com.mnemomed.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Mnemo Med",
        "width": 1200,
        "height": 820,
        "minWidth": 380,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Education",
    "shortDescription": "Source-locked study intelligence for medical school.",
    "longDescription": "Mnemo Med turns lecture notes, slides, and professor wording into verified review sheets, Anki cards, practice questions, and cram plans — local-first, with no account required.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
